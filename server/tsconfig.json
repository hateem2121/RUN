{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "../dist/server",
    "tsBuildInfoFile": "../dist/server/.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@shared": ["../shared/index.ts"],
      "@shared/*": ["../shared/*"],
      "@run-remix/shared": ["../shared/index.ts"],
      "@run-remix/shared/*": ["../shared/*"],
      "lru-cache": ["../node_modules/lru-cache"]
    },
    "lib": ["es2022"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": ["node_modules", "../dist", "**/*.spec.ts", "**/*.test.ts", "scripts/legacy"],
  "references": [{ "path": "../shared" }]
}
