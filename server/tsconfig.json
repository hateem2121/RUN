{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "../dist/server",
    "tsBuildInfoFile": "../dist/server/.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["../shared/*"]
    },
    "lib": ["es2022"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["**/*.ts", "**/*.d.ts"],
  "exclude": ["node_modules", "../dist", "**/*.spec.ts", "**/*.test.ts"],
  "references": [{ "path": "../shared" }]
}
