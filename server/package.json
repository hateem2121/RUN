{
  "name": "@run-remix/server",
  "version": "4.1.2",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.4.0",
    "@gltf-transform/core": "^4.2.1",
    "@gltf-transform/extensions": "^4.2.1",
    "@gltf-transform/functions": "^4.2.1",
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/secret-manager": "^6.1.1",
    "@google-cloud/storage": "^5.18.3",
    "@google-cloud/tasks": "^6.2.1",
    "@neondatabase/serverless": "^1.0.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation-pino": "^0.40.0",
    "@opentelemetry/resources": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/sdk-trace-base": "^2.2.0",
    "@opentelemetry/semantic-conventions": "^1.38.0",
    "@react-router/express": "^7.14.2",
    "@run-remix/shared": "*",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-session": "^1.18.2",
    "express-static-gzip": "^3.0.1",
    "ffprobe-static": "^3.1.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "lru-cache": "^11.2.2",
    "multer": "^2.1.0",
    "neverthrow": "^8.1.1",
    "nodemailer": "^9.0.1",
    "opossum": "^9.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "sharp": "^0.34.5",
    "supertest": "^7.1.4",
    "ws": "^8.18.0",
    "zod": "^4.2.1",
    "zod-express-middleware": "^1.4.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.5",
    "@types/express-session": "^1.18.2",
    "@types/ffprobe-static": "^2.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.10.0",
    "@types/nodemailer": "^7.0.2",
    "@types/opossum": "^8.1.9",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.15.5",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.5.13",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.4",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage -c ../vitest.config.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsc -b && esbuild index.ts --bundle --platform=node --target=node24 --packages=external --format=esm --outfile=../dist/index.js",
    "predev": "npm run kill:all; echo '✓ Clean dev environment ready'",
    "dev": "DOTENV_CONFIG_PATH=../.env PORT=5002 NODE_OPTIONS='--expose-gc' tsx watch --ignore '**/node_modules' --ignore '../client' --ignore '../client/src' --ignore 'dist' --ignore '.cache' --ignore 'coverage' --ignore '.git' --ignore '*.log' index.ts",
    "dev:mock": "MOCK_DB=true PORT=5002 NODE_OPTIONS='--expose-gc' tsx watch --ignore '**/node_modules' --ignore '../client' --ignore '../client/src' --ignore 'dist' --ignore '.cache' --ignore 'coverage' --ignore '.git' --ignore '*.log' index.ts",
    "dev:server": "PORT=5002 tsx watch src/index.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "build:ssr": "npm run build",
    "start": "node --import tsx ../dist/index.js"
  },
  "overrides": {
    "uuid": "14.0.0"
  }
}
