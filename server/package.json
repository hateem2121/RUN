  "scripts": {
    "test": "vitest run",
    "build": "tsc -b && esbuild index.ts --bundle --platform=node --target=node24 --packages=external --format=esm --outfile=../dist/index.js",
    "predev": "npx kill-port 5002 2>/dev/null; pkill -f 'tsx watch.*index.ts' 2>/dev/null; echo '✓ Clean dev environment ready'",
    "dev": "PORT=5002 tsx watch --ignore '**/node_modules' --ignore '../client' --ignore '../client/src' --ignore 'dist' --ignore '.cache' --ignore 'coverage' --ignore '.git' --ignore '*.log' index.ts",
    "dev:mock": "MOCK_DB=true PORT=5002 tsx watch --ignore '**/node_modules' --ignore '../client' --ignore '../client/src' --ignore 'dist' --ignore '.cache' --ignore 'coverage' --ignore '.git' --ignore '*.log' index.ts",
    "dev:server": "PORT=5002 tsx watch src/index.ts",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "build:ssr": "npm run build",
    "start": "node --import tsx ../dist/index.js"
  }
