# Core Server Configuration
PORT=5002
NODE_ENV=development
# Database Connection (With Neon Pooler)
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech:5432/dbname

# Authentication (Google OAuth)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
SESSION_SECRET=your_random_session_secret
INITIAL_ADMIN_EMAIL=admin@example.com

# Caching (Upstash Redis - Optional for Dev, Required for Prod)
UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=...

# Monitoring (Sentry - Optional)
SENTRY_DSN=...
SENTRY_ORG=...
SENTRY_PROJECT=...
SENTRY_AUTH_TOKEN=...

# Security (Optional)
FORCE_HTTPS=true

# OpenTelemetry Tracing (enabled by default in production, set to "false" to disable)
# ENABLE_OTEL=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
OTEL_SERVICE_NAME=run-remix-api
