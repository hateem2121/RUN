{
  "ignorePatterns": [
    {
      "pattern": "^http://localhost"
    },
    {
      "pattern": "^http://127.0.0.1"
    },
    {
      "pattern": "^file://"
    },
    {
      "pattern": "wear-run\\.com"
    },
    {
      "pattern": "runapparel\\.com"
    },
    {
      "pattern": "^\\.\\./\\.\\./plans/"
    },
    {
      "pattern": "^\\.\\./\\.\\./audit-reports/"
    },
    {
      "pattern": "^\\.\\./\\.\\./client/"
    }
  ],
  "replacementPatterns": [
    {
      "pattern": "^/",
      "replacement": "{{BASEURL}}/"
    }
  ],
  "retryOn429": true,
  "aliveStatusCodes": [200, 206]
}
