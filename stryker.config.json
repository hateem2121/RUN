{
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["html", "clear-text", "progress", "dashboard"],
  "coverageAnalysis": "perTest",
  "mutate": [
    "server/lib/**/*.ts",
    "shared/schema/**/*.ts",
    "!**/*.test.ts",
    "!**/*.spec.ts",
    "!**/node_modules/**"
  ],
  "ignorePatterns": [
    "node_modules",
    "dist",
    "client",
    "e2e",
    "**/*.d.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "concurrency": 4,
  "timeoutMS": 60000,
  "incremental": true,
  "incrementalFile": ".stryker-tmp/incremental.json",
  "dashboard": {
    "project": "github.com/hateem2121/RUN",
    "version": "main",
    "reportType": "full"
  },
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "plugins": [
    "@stryker-mutator/vitest-runner"
  ]
}
