{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "outDir": "../dist/client",
    "tsBuildInfoFile": "../dist/client/.tsbuildinfo",
    "baseUrl": ".",
    "paths": {
      "@/*": ["app/*"],
      "@shared": ["../shared/index.ts"],
      "@shared/*": ["../shared/*"],
      "@run-remix/shared": ["../shared/index.ts"],
      "@run-remix/shared/*": ["../shared/*"],
      "@assets/*": ["../attached_assets/*"]
    },
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["app/**/*", "src/types/**/*", "vite.config.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "**/*.spec.ts",
    "**/*.test.ts",
    "../server/**/*",
    "**/*.server.ts"
  ]
}
