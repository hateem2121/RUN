{
  "name": "run-remix-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev": "npm run dev:server",
    "dev:server": "npm run --workspace=@run-remix/server dev",
    "build": "npm run build --workspaces",
    "build:client": "npm run build --workspace=@run-remix/client",
    "build:server": "npm run build --workspace=@run-remix/server",
    "migrate:deploy": "npm run --workspace=@run-remix/server db:migrate",
    "db:push": "npm run --workspace=@run-remix/server db:push",
    "typecheck": "tsc -b client server",
    "check": "biome check .",
    "check:audit": "audit-ci --high",
    "check:apply": "biome check --write .",
    "verify:build": "npm run build && npm run typecheck",
    "verify:tech-integrity": "npm run verify:build && npm run check:audit",
    "test": "vitest run",
    "test:contract": "vitest run shared/tests",
    "test:integration": "vitest run server/tests",
    "kill:all": "pkill -f 'RUN-Remix' || echo 'No processes found'",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^24.10.0",
    "@types/node-fetch": "^2.6.13",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitest/coverage-v8": "^4.0.6",
    "audit-ci": "^7.1.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.39.2",
    "eslint-plugin-tailwindcss": "^4.0.0-beta.0",
    "husky": "^9.1.7",
    "knip": "^5.75.2",
    "lint-staged": "^16.2.7",
    "node-fetch": "^3.3.2",
    "playwright-core": "^1.57.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write"
    ],
    "*.{js,json,md}": [
      "biome check --write"
    ]
  }
}
