{
  "name": "rest-express",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "PORT=5001 NODE_ENV=development tsx watch server/index.ts",
    "build": "npm run build:client && npm run build:ssr && npm run build:server && npm run build:express",
    "build:client": "vite build --ssrManifest --manifest",
    "build:ssr": "vite build --ssr src/entry-server.tsx",
    "build:server": "tsc -b server",
    "verify:build": "node scripts/verify-build.cjs",
    "verify:serving": "node scripts/verify-production-serving.js",
    "verify:sourcemaps": "tsx scripts/verify-source-maps.ts",
    "ci:checks": "npm install && npm run check && npm run check:react && npm run build && npm run verify:sourcemaps && tsx scripts/verify-ssr-css.ts && npm run check:assets && npm run test:e2e",
    "check:react": "node scripts/check-single-react.mjs",
    "check:router": "node scripts/check-router.cjs",
    "check:assets": "node scripts/check-assets.mjs",
    "build:express": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "PORT=5001 NODE_ENV=production node dist/index.js",
    "verify:release": "npm run build && npm run check:router && node scripts/check-dupes.cjs && cross-env E2E_MODE=production npx playwright test \"e2e/visual/\"",
    "check": "biome check .",
    "check:apply": "biome check --write .",
    "test": "vitest run --exclude tests/integration",
    "test:integration": "vitest run tests/integration",
    "test:crash": "vitest run tests/integration/crash.test.ts",
    "db:push": "drizzle-kit push",
    "test:performance": "node scripts/performance-test.js",
    "test:e2e": "playwright test e2e/regression-guardrails.spec.ts",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts",
    "test:e2e:prod": "E2E_TARGET=prod npx playwright test --project=prod-chromium",
    "lint": "biome lint .",
    "lint:css-contract": "node scripts/lint-css-contract.mjs",
    "test:visual": "npx playwright test e2e/visual/regression.spec.ts",
    "test:visual:update": "npx playwright test e2e/visual/regression.spec.ts --update-snapshots",
    "test:all-safeguards": "npm run lint:css-contract && npm run test:visual",
    "test:hardening": "npm run lint && node scripts/lint-determinism.mjs && npm run test:e2e",
    "analyze": "cross-env DATABASE_URL='postgres://mock:5432/mock' knip --no-exit-code",
    "prepare": "husky"
  },
