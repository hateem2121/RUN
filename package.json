{
  "name": "run-remix-monorepo",
  "version": "1.0.0",
  "packageManager": "npm@10.9.2",
  "private": true,
  "type": "module",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev:server": "npm run --workspace=@run-remix/server dev",
    "start": "npm run --workspace=@run-remix/server start",
    "build:client": "npm run build --workspace=@run-remix/client",
    "build:server": "npm run build --workspace=@run-remix/server",
    "migrate:deploy": "npm run --workspace=@run-remix/server db:migrate",
    "db:push": "npm run --workspace=@run-remix/server db:push",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:integration": "vitest run tests/integration",
    "lint": "biome check .",
    "check": "npm run typecheck && npm run lint",
    "check:apply": "biome check --write .",
    "check:bundle": "bundlesize",
    "typecheck": "tsc -b",
    "build:ssr": "npm run --workspace=@run-remix/server build:ssr",
    "verify:ssr": "tsx scripts/verify-ssr-template.ts && node scripts/check-ssr-invariants.js",
    "verify:tech-integrity": "tsx scripts/verify-tech-integrity.ts",
    "check:invariants": "node scripts/check-ssr-invariants.js",
    "kill:all": "pkill -f 'RUN-Remix' || echo 'No processes found'",
    "prepare": "husky"
  },
  "bundlesize": [
    {
      "path": "./client/build/client/assets/index-*.js",
      "maxSize": "150 kB"
    },
    {
      "path": "./client/build/client/assets/root-*.css",
      "maxSize": "50 kB"
    }
  ],
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^24.10.0",
    "@types/node-fetch": "^2.6.13",
    "@types/testing-library__jest-dom": "^5.14.9",
    "@vitest/coverage-v8": "^4.0.6",
    "audit-ci": "^7.1.0",
    "bundlesize": "^0.18.2",
    "drizzle-kit": "^0.31.4",
    "husky": "^9.1.7",
    "knip": "^5.75.2",
    "lint-staged": "^16.2.7",
    "markdown-link-check": "^3.14.2",
    "node-fetch": "^3.3.2",
    "playwright-core": "^1.57.0",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "turbo": "^2.7.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write"
    ],
    "*.{js,json,md}": [
      "biome check --write"
    ]
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "yargs": "^18.0.0"
  }
}
