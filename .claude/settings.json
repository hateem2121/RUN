{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cd /home/user/RUN && npm run check:apply --silent 2>&1 | tail -10"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '\n\u26a0\ufe0f  Protocol 0 Reminder: Update task_plan.md and findings.md before closing this session.\n    - task_plan.md  \u2192 what was planned / what remains\n    - findings.md   \u2192 what was done, discovered, and any follow-ups\n    Then run: npm run verify:tech-integrity'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "deny": [
      "Write(.env)",
      "Write(.env.local)",
      "Write(.env.development)",
      "Write(.env.production)",
      "Write(.env.test)",
      "Edit(.env)",
      "Edit(.env.local)",
      "Edit(.env.development)",
      "Edit(.env.production)",
      "Edit(.env.test)",
      "Write(gcs-service-account-key.json)",
      "Write(*-service-account-key.json)"
    ]
  }
}
