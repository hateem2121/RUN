{
  "mcpServers": {
    "memory": { "command": "npx", "args": ["-y", "@modelcontextprotocol/server-memory"] },
    "google-maps-platform-code-assist": {
      "command": "npx",
      "args": ["-y", "@googlemaps/code-assist-mcp@0.2.0"]
    },
    "sequentialthinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@0.0.38"],
      "alwaysAllow": [
        "browser_navigate",
        "browser_take_screenshot",
        "browser_console_messages",
        "browser_snapshot"
      ]
    },
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"],
      "env": { "DEFAULT_MINIMUM_TOKENS": "" }
    },
    "figma-dev-mode": {
      "type": "sse",
      "url": "http://127.0.0.1:3845/sse",
      "disabled": true,
      "alwaysAllow": []
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/hateemjamshaid/Documents/RUN-Remix"
      ],
      "alwaysAllow": ["read_multiple_files", "list_directory", "read_text_file"]
    },
    "fireproof": {
      "command": "node",
      "args": ["/Users/hateemjamshaid/Documents/RUN-Remix/build/index.js"],
      "disabled": true,
      "alwaysAllow": []
    },
    "git": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/inspector",
        "uvx",
        "mcp-server-git",
        "--repository",
        "/Users/hateemjamshaid/Documents/RUN-Remix"
      ],
      "disabled": true,
      "alwaysAllow": []
    },
    "github": {
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "-e",
        "GITHUB_PERSONAL_ACCESS_TOKEN",
        "-e",
        "GITHUB_TOOLSETS",
        "-e",
        "GITHUB_READ_ONLY",
        "ghcr.io/github/github-mcp-server"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "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",
        "GITHUB_TOOLSETS": "repo+workflow",
        "GITHUB_READ_ONLY": ""
      }
    },
    "git-mcp": {
      "command": "npx",
      "args": ["-y", "mcp-remote@0.1.29", "https://gitmcp.io/hateem2121/RUN"],
      "alwaysAllow": ["fetch_generic_url_content"]
    },
    "neon": { "command": "npx", "args": ["-y", "mcp-remote", "https://mcp.neon.tech/sse"] }
  }
}
